[gd_scene format=3 uid="uid://d3u3j3u3j3u3"]

[sub_resource type="GDScript" id="GDScript_fish"]
script/source = "extends Node2D

## Decorative fish — reads all values from GameConfig.

var swim_speed: float = 60.0
var vertical_drift: float = 20.0
var _direction: float = 1.0
var _time_offset: float = 0.0
var _base_y: float = 0.0
var _body_color: Color = Color.WHITE

func _ready() -> void:
	swim_speed = GameConfig.FISH_BASE_SWIM_SPEED
	vertical_drift = GameConfig.FISH_VERTICAL_DRIFT
	_time_offset = randf() * TAU
	_base_y = position.y
	_direction = [-1.0, 1.0].pick_random()
	swim_speed *= randf_range(GameConfig.FISH_SPEED_VARIATION_MIN, GameConfig.FISH_SPEED_VARIATION_MAX)
	_body_color = Color(
		randf_range(0.6, 1.0),
		randf_range(0.4, 0.9),
		randf_range(0.2, 0.6),
		0.7
	)
	scale.x = _direction
	queue_redraw()

func _process(delta: float) -> void:
	position.x += _direction * swim_speed * delta
	_time_offset += delta * 1.5
	position.y = _base_y + sin(_time_offset) * vertical_drift
	if _direction > 0 and position.x > GameConfig.FISH_WRAP_RIGHT:
		position.x = GameConfig.FISH_WRAP_LEFT
		_base_y += randf_range(-30, 30)
	elif _direction < 0 and position.x < GameConfig.FISH_WRAP_LEFT:
		position.x = GameConfig.FISH_WRAP_RIGHT
		_base_y += randf_range(-30, 30)

func _draw() -> void:
	var body_pts: PackedVector2Array = PackedVector2Array()
	for i in range(12):
		var angle: float = TAU * i / 12.0
		body_pts.append(Vector2(cos(angle) * 12, sin(angle) * 7))
	draw_colored_polygon(body_pts, _body_color)
	var tail: PackedVector2Array = PackedVector2Array([
		Vector2(-12, 0), Vector2(-20, -8), Vector2(-20, 8)])
	draw_colored_polygon(tail, _body_color.darkened(0.2))
	draw_circle(Vector2(6, -2), 2.0, Color.WHITE)
	draw_circle(Vector2(7, -2), 1.0, Color.BLACK)
"

[node name="Fish" type="Node2D"]
script = SubResource("GDScript_fish")
